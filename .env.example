# ── API Keys Configuration ────────────────────────────────────────────────────
# Copy this file to .env and fill in your actual API keys
# DO NOT commit the .env file to Git

# Oxylabs: username:password pairs separated by commas
# Example: OXYLABS_KEYS=user1:pass1,user2:pass2
OXYLABS_KEYS=your_username:your_password

# ScrapingBee: API keys separated by commas
SCRAPINGBEE_KEYS=your_scrapingbee_key_1,your_scrapingbee_key_2

# ScraperAPI: API keys separated by commas
SCRAPERAPI_KEYS=your_scraperapi_key_1,your_scraperapi_key_2

# ZenRows: API keys separated by commas
ZENROWS_KEYS=your_zenrows_key_1,your_zenrows_key_2

# Apify: API keys separated by commas
APIFY_KEYS=your_apify_key_1,your_apify_key_2

# Scrapestack: API keys separated by commas
SCRAPESTACK_KEYS=your_scrapestack_key_1,your_scrapestack_key_2

# ── Optional Configuration ────────────────────────────────────────────────────
# Geographic location for searches (default: California,United States)
GEO_LOCATION=California,United States

# Maximum number of requests to make (default: 5000)
MAX_REQUESTS=5000
